# API Configuration
# For local development
API_BASE_URL=http://localhost:5173

# For production (uncomment and use this instead)
# API_BASE_URL=https://rally-timer-dev.peteri.se

# Serial port (auto-detected if empty)
SERIAL_PORT=

# Reader settings
DEDUP_SECONDS=2
# Minimum signal strength to accept a read, in dBm (always negative;
# closer to 0 = stronger). 200 would silently reject every tag.
RSSI_THRESHOLD=-65
EPC_CHARS=8

# NTP settings
NTP_SERVER=lul1.ntp.se

# UUID (auto-generated if empty)
# GATE_UUID=
